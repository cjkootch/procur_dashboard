# Database
DATABASE_URL=
DIRECT_DATABASE_URL=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_PRICER_PRICE_ID=

# Resend
RESEND_API_KEY=
# Default From: header for outbound email.send. RFC-5322 envelope —
# either a bare address or "Name <addr>". Domain MUST match a verified
# Resend domain (otherwise sends bounce). Falls back to a procur-owned
# default when unset.
RESEND_FROM_ADDRESS=
# Svix-signed webhook secret for inbound emails. Used by
# /api/webhooks/resend-inbound to verify the payload before turning it
# into a touchpoint + thread + message row. Get it from the Resend
# dashboard's "Webhooks" tab when you wire the inbound webhook.
RESEND_INBOUND_WEBHOOK_SECRET=

# Twilio — Phase 7 messaging + voice. SMS, WhatsApp, outbound calls
# all flow through executors in packages/ai/src/executors/twilio.ts.
# Inbound + status/recording callbacks land at /api/webhooks/twilio.
TWILIO_ACCOUNT_SID=
# Either TWILIO_API_KEY + TWILIO_API_SECRET OR TWILIO_AUTH_TOKEN.
# API-key auth is preferred for production (revocable per-app);
# auth-token fallback exists for local dev.
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_AUTH_TOKEN=
# Outbound from-number in E.164 (e.g. +18324927169). SMS uses this
# directly; voice uses it as caller-id; WhatsApp falls back to
# `whatsapp:${this}` if TWILIO_WHATSAPP_FROM is unset.
TWILIO_PHONE_NUMBER=
# Optional explicit WhatsApp sender (e.g. whatsapp:+14155238886).
# Leave unset until WhatsApp Business onboarding is complete.
TWILIO_WHATSAPP_FROM=

# Voice-bridge (Phase 7.5). Fly app at procur-voice-bridge.fly.dev that
# bridges Twilio Media Streams ↔ OpenAI Realtime when an outbound call
# has aiMode=true. The TwiML route uses this as the <Connect><Stream>
# url. Set to wss://procur-voice-bridge.fly.dev/twilio in production.
VOICE_BRIDGE_WSS_URL=
# OpenAI Realtime endpoint the voice-bridge dials. Defaults inside the
# bridge to wss://api.openai.com/v1/realtime; override for staging or
# regional endpoints.
OPENAI_REALTIME_URL=

# Sanctions screening (Phase 6). CSL = Consolidated Screening List
# from trade.gov. Free key from https://api.trade.gov/. Used by
# packages/ai/src/agents/agents/sanctions-screening.ts. Empty key =
# OFAC/UK-OFSI/EU still work (separate ingest paths) but CSL screens
# are skipped.
TRADE_GOV_CSL_API_KEY=

# Assistant feature flags (optional)
# Set to "true" to bypass the per-month AI budget kill-switch. Use
# only for one-off staging or smoke tests; production should leave
# unset so BudgetExceededError fires when the cap is hit.
ASSISTANT_DISABLE_BUDGET=
# Set to "true" to enable the Anthropic web_search server-tool for
# the main assistant (off by default — adds material per-turn cost).
ASSISTANT_WEB_SEARCH_ENABLED=

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional: route Anthropic + OpenAI calls through Cloudflare AI Gateway
# for observability (per-call cost/latency) and automatic prompt/embedding
# caching. Format: https://gateway.ai.cloudflare.com/v1/<account-id>/<gateway-name>
# (no trailing /anthropic or /openai — code appends per-provider).
CF_AI_GATEWAY_BASE_URL=

# Unstructured.io
UNSTRUCTURED_API_KEY=
UNSTRUCTURED_API_URL=

# Vercel Blob (auto-provided in Vercel deployments; set manually on trigger.dev)
BLOB_READ_WRITE_TOKEN=

# Trigger.dev
TRIGGER_API_KEY=
TRIGGER_API_URL=

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
AXIOM_TOKEN=
AXIOM_DATASET=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=

# App config
NEXT_PUBLIC_APP_URL=https://app.procur.app
NEXT_PUBLIC_DISCOVER_URL=https://discover.procur.app
NEXT_PUBLIC_MARKETING_URL=https://procur.app
NEXT_PUBLIC_ADMIN_URL=https://admin.procur.app
